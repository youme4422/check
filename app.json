{
  "expo": {
    "name": "Check In Safe",
    "slug": "check-in-safe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "checkinsafe",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jan26.checkinsafe",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.jan26.checkinsafe",
      "versionCode": 1,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "com.google.android.gms.permission.AD_ID",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#1A7F64",
          "defaultChannel": "checkin-safe-reminders"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F3F7F5"
        }
      ],
      "./plugins/with-secure-android-manifest"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "apiBaseUrl": "http://192.168.35.213:4000",
      "eas": {
        "projectId": "fa86ed90-4ef6-4ceb-900f-b2cf74eeb70c"
      }
    },
    "owner": "younme0404"
  }
}
