PORT=4000
DATABASE_URL=
# Or use separate Postgres fields instead of DATABASE_URL:
PGHOST=
PGPORT=5432
PGDATABASE=
PGUSER=
PGPASSWORD=
# false recommended for Supabase pooler/direct unless you use custom CA
PGSSLMODE_REJECT_UNAUTHORIZED=false
SERVER_API_KEY=replace_with_strong_api_key

# LINE + Telegram + Email messaging
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret

# Deadman cooldown: one alert per user within this window (minutes)
MESSAGE_COOLDOWN_MINUTES=60
# Deadman scheduler interval (seconds)
DEADMAN_SCAN_INTERVAL_SECONDS=60
# Link code validity window (minutes)
LINK_CODE_TTL_MINUTES=30
# Monthly auto-send cap per channel: effective limit is (free limit - SAFETY_MARGIN_MESSAGES)
SAFETY_MARGIN_MESSAGES=10
FREE_LIMIT_TELEGRAM_PER_MONTH=0
FREE_LIMIT_LINE_PER_MONTH=200
FREE_LIMIT_EMAIL_PER_MONTH=3000

# Rate limiting (fixed window)
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_PER_IP=120
RATE_LIMIT_PER_USER=60

# Optional channels
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
